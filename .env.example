APP_NAME=TunAcademy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ──────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tunacademy
DB_USERNAME=tunacademy
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# ─── Cache / Session / Queue ───────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ──────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tunacademy.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Laravel Reverb (WebSocket) ────────────────────────────────────────────
REVERB_APP_ID=tunacademy
REVERB_APP_KEY=tunacademy-key
REVERB_APP_SECRET=tunacademy-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── TURN Server (WebRTC) ──────────────────────────────────────────────────
TURN_HOST=localhost
TURN_PORT=3478
TURN_USERNAME=tunacademy
TURN_PASSWORD=secret

VITE_TURN_HOST="${TURN_HOST}"
VITE_TURN_PORT="${TURN_PORT}"
VITE_TURN_USERNAME="${TURN_USERNAME}"
VITE_TURN_PASSWORD="${TURN_PASSWORD}"

# ─── Anthropic / AI Chat ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Vite ──────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"
